@page
@model QuizGame.Pages.PlayModel
@{
    ViewData["Title"] = "Play";
    Layout = "_PlayerLayout";
}
@if (Model.Session is null || Model.Player is null)
{
    <div class="alert alert-warning">Game session not found.</div>
}
else if (Model.Question is null)
{
    <div class="alert alert-info">Waiting for the next question…</div>
}
else
{
    <div class="mobile-play">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="fw-bold">@Model.Player.Username</div>
            <div class="badge bg-danger fs-6">Question @Model.Session.CurrentQuestionIndex</div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-body text-center">
                <div class="timer-circle mx-auto mb-3"><span id="timeLeft">@Model.SecondsLeft</span></div>
                <h3>@Model.Question.Text</h3>
            </div>
        </div>

        @if (Model.AlreadyAnswered)
        {
            <div class="alert alert-success text-center">Answer submitted. Waiting for host…</div>
        }
        else
        {
            <form method="post">
                <input type="hidden" asp-for="SessionId" />
                <input type="hidden" asp-for="PlayerId" />
                <div class="row g-3">
                    <div class="col-12"><button type="submit" name="SelectedAnswer" value="@Model.Question.OptionA" class="btn btn-answer a w-100">@Model.Question.OptionA</button></div>
                    <div class="col-12"><button type="submit" name="SelectedAnswer" value="@Model.Question.OptionB" class="btn btn-answer b w-100">@Model.Question.OptionB</button></div>
                    <div class="col-12"><button type="submit" name="SelectedAnswer" value="@Model.Question.OptionC" class="btn btn-answer c w-100">@Model.Question.OptionC</button></div>
                    <div class="col-12"><button type="submit" name="SelectedAnswer" value="@Model.Question.OptionD" class="btn btn-answer d w-100">@Model.Question.OptionD</button></div>
                </div>
            </form>
        }
    </div>
}
@section Scripts {
<script>
let left = @Model.SecondsLeft;
const counter = document.getElementById('timeLeft');
if (counter) {
    const timer = setInterval(() => {
        left--;
        counter.textContent = Math.max(left, 0);
        if (left <= 0) clearInterval(timer);
    }, 1000);
}
const sessionId = "@Model.SessionId";
if (sessionId) {
    const connection = new signalR.HubConnectionBuilder().withUrl("/gamehub").build();
    connection.on("SessionUpdated", () => location.reload());
    connection.start().then(() => connection.invoke("JoinSessionGroup", sessionId));
}
</script>
}
