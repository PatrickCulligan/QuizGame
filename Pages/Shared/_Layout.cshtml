<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuizGame</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-page="/Index">QuizGame Live</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-page="/Host">Host</a>
                <a class="nav-link" asp-page="/Join">Join</a>
                <a class="nav-link" asp-page="/Results">Results</a>

                @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                {
                    <a class="nav-link" asp-page="/Admin">Create Quiz</a>
                }
            </div>

            <div class="ms-auto navbar-nav">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <form method="post" asp-page="/Account/Logout" class="d-inline">
                        <button type="submit" class="btn btn-link nav-link">Logout (@User.Identity.Name)</button>
                    </form>
                }
                else
                {
                    <a class="nav-link" asp-page="/Account/Login">Login</a>
                }
            </div>
        </div>
    </nav>

    <div class="container pb-5">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
