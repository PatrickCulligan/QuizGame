 <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuizGame</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-page="/Index">QuizGame Live</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-page="/Admin">Admin</a>
                <a class="nav-link" asp-page="/Host">Host</a>
                <a class="nav-link" asp-page="/Join">Join</a>
                <a class="nav-link" asp-page="/Results">Results</a>
            </div>
        </div>
    </nav>

    <div class="container pb-5">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
