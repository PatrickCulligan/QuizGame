<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold">QuizGame Live</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-page="/Join">Join</a>

                @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                {
                    <a class="nav-link" asp-page="/Quizzes/Create">Create Quiz</a>
                }

                @{
                    // explicit per-page override flag (set in pages that need to hide login)
                    var hideLoginFlag = ViewData["HideLogin"] as bool? ?? false;

                    // defensive check: route data "page" can vary; check for Join presence as fallback
                    var currentPage = (string?)ViewContext.RouteData.Values["page"] ?? string.Empty;
                    var hideByPage = !string.IsNullOrEmpty(currentPage) &&
                                     (currentPage.IndexOf("Join", System.StringComparison.OrdinalIgnoreCase) >= 0 ||
                                      string.Equals(currentPage, "/Join", System.StringComparison.OrdinalIgnoreCase));
                }

                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <form method="post" asp-page="/Account/Logout" class="d-inline">
                        <button type="submit" class="btn btn-link nav-link">Logout (@User.Identity.Name)</button>
                    </form>
                }
                else
                {
                    @* hide login when either explicit flag is set or fallback page match *@
                    if (!hideLoginFlag && !hideByPage)
                    {
                        <a class="nav-link" asp-page="/Account/Login">Login</a>
                    }
                }
            </div>
        </div>
    </nav>

    <div class="container pb-5">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
